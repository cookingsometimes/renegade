{
    "name": "renegade",
    "description": "Custom UI wrapper for Xeno executor",
    "version": "2.0.3",
    "license": "MIT",
    "author": {
        "name": "Renegade"
    },
    "main": "dist-main/index.js",
    "scripts": {
        "build": "vite build",
        "check": "npm lint && npm typecheck && npm prettier:check && npm test",
        "dev": "vite",
        "lint": "eslint .",
        "package:publish": "electron-builder --config electron-builder.config.js --publish always",
        "package": "electron-builder --config electron-builder.config.js",
        "prettier:check": "prettier --check -- src/**/*.{ts,tsx}",
        "prettier:write": "prettier --write -- src/**/*.{ts,tsx}",
        "test:coverage": "vitest run --coverage",
        "test:watch": "vitest",
        "test": "vitest run",
        "typecheck": "pnpm typecheck:main && pnpm typecheck:preload && pnpm typecheck:renderer",
        "typecheck:main": "tsc -p src/main/tsconfig.json --noEmit",
        "typecheck:preload": "tsc -p src/preload/tsconfig.json --noEmit",
        "typecheck:renderer": "tsc -p src/renderer/tsconfig.json --noEmit"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.0.9",
        "@types/react": "^19.2.8",
        "@types/react-dom": "^19.2.3",
        "@types/ws": "^8.18.1",
        "@vitejs/plugin-react": "^6.0.1",
        "@vitest/coverage-v8": "^4.0.17",
        "electron": "^42.4.0",
        "electron-builder": "^26.6.0",
        "eslint": "^10.2.0",
        "globals": "^17.0.0",
        "prettier": "^3.8.0",
        "prettier-plugin-organize-imports": "^4.3.0",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.58.0",
        "vite": "^8.0.3",
        "vite-plugin-electron": "^0.29.1",
        "vitest": "^4.0.17"
    },
    "dependencies": {
        "electron-updater": "^6.8.9",
        "extract-zip": "^2.0.1",
        "monaco-editor": "^0.55.1",
        "react": "^19.2.3",
        "react-dom": "^19.2.3"
    }
}
